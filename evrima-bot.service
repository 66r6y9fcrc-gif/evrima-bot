[Unit]
Description=The Isle Evrima Discord Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=tuco
WorkingDirectory=/home/tuco/evrima-bot
ExecStart=/usr/bin/node /home/tuco/evrima-bot/src/index.js
Restart=always
RestartSec=5
# Umgebung laden
EnvironmentFile=/home/tuco/evrima-bot/.env
# SD-Karte schonen: Logs ins Journal, nicht in Datei
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
